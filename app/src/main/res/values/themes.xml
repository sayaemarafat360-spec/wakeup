<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base Application Theme -->
    <style name="Theme.WakeUpWarrior" parent="android:Theme.Material.NoActionBar">
        <item name="android:colorPrimary">@color/primary</item>
        <item name="android:colorPrimaryDark">@color/background</item>
        <item name="android:colorAccent">@color/primary</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>
    
    <!-- Alarm Full Screen Theme -->
    <style name="Theme.WakeUpWarrior.Alarm" parent="Theme.WakeUpWarrior">
        <item name="android:windowShowWallpaper">false</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>
    
    <!-- Splash Screen Theme -->
    <style name="Theme.WakeUpWarrior.Splash" parent="Theme.WakeUpWarrior">
        <item name="android:windowBackground">@color/background</item>
    </style>
</resources>
